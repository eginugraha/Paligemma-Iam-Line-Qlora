# Copy this file to `.env` and fill in your real values. `.env` is gitignored, so secrets
# stay out of the repo. Every sub-project's config.py loads this file automatically via
# python-dotenv at import time, so these apply project-wide (SP-1 training/export, SP-2 API,
# SP-3 CLIs). You can also just `export` any of them in your shell — a shell value wins over
# the .env value (load_dotenv does not override real exports). All keys are OPTIONAL; each has
# a sensible default in code, except secrets (HF_TOKEN, HTR_RUNPOD_API_KEY) which you must set
# yourself for the operations that need them.

# --- SP-1: training & Hugging Face export (src/htr_sp1/config.py) ---
# Hub repo the fine-tuned model is pushed to (push_to_hub, private). Override for your account.
HTR_HUB_REPO_ID=your-username/paligemma-iam-line-qlora
# Where training artifacts are written locally (Colab/Drive can point this elsewhere).
HTR_OUTPUT_DIR=outputs/sp1
# Hugging Face access token — NOT read by our code directly; huggingface_hub reads it to
# authenticate push_to_hub / private model downloads. Equivalent to `huggingface-cli login`.
# Create one at https://huggingface.co/settings/tokens (needs write scope to push).
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- SP-2: backend & RunPod Serverless inference (src/htr_sp2/config.py) ---
# Engine: "fake" (default, no GPU) or "runpod".
HTR_ENGINE=fake
# Only needed when HTR_ENGINE=runpod:
HTR_RUNPOD_ENDPOINT_ID=your-endpoint-id
HTR_RUNPOD_API_KEY=your-runpod-api-key
# Set on the RunPod GPU WORKER (runpod/handler.py): which adapter to serve + base load precision.
# HTR_BASE_PRECISION: "4bit" (default, lightest, needs CUDA) | "bf16" | "fp32".
HTR_ADAPTER_ID=eginugraha/paligemma-iam-line-qlora-adapter
HTR_BASE_PRECISION=4bit
# Optional tuning knobs (defaults shown):
HTR_RUNPOD_TIMEOUT=180
HTR_M2_MAX_NEW_TOKENS=256

# --- SP-3: PostgreSQL + pgvector store (src/htr_sp3/config.py) ---
# Connection string for the vocabulary store. Format:
#   postgresql://USER:PASSWORD@HOST:PORT/DBNAME
HTR_PG_DSN=postgresql://user:pass@localhost:5432/htr

# --- SP-5: MinIO object storage for uploaded images (src/htr_sp5/config.py) ---
#   Leave unset to disable upload persistence (the /v1/detect stream still works).
#   HTR_PG_DSN (above) is also reused by SP-5 for eval_run / eval_result / upload metadata.
HTR_MINIO_ENDPOINT=localhost:9000
HTR_MINIO_ACCESS_KEY=minioadmin
HTR_MINIO_SECRET_KEY=minioadmin
HTR_MINIO_BUCKET=htr-uploads
HTR_MINIO_SECURE=false
