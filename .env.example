# Copy this file to `.env` and fill in your real values. `.env` is gitignored, so secrets
# stay out of the repo. The SP-3 CLIs (scripts/ingest_sp3.py, scripts/tune_sp3.py) load it
# automatically via python-dotenv; you can also just `export` these in your shell instead.

# --- SP-3: PostgreSQL + pgvector store ---
# Connection string for the vocabulary store. Format:
#   postgresql://USER:PASSWORD@HOST:PORT/DBNAME
HTR_PG_DSN=postgresql://user:pass@localhost:5432/htr

# --- SP-2: RunPod Serverless inference (only when HTR_ENGINE=runpod) ---
# HTR_ENGINE=runpod
# HTR_RUNPOD_ENDPOINT_ID=your-endpoint-id
# HTR_RUNPOD_API_KEY=your-api-key
